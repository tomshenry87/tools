[Unit]
Description=Firmware Dashboard Server
After=network.target

[Service]
Type=simple
User=tom
WorkingDirectory=/home/tom/tools/fleet-server
ExecStart=/usr/local/bin/gunicorn -w 2 -b 127.0.0.1:5000 server:app
Restart=always
RestartSec=5
Environment=PATH=/usr/local/bin:/usr/bin:/bin

[Install]
WantedBy=multi-user.target
